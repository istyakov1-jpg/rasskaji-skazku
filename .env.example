# ============================================================
# Расскажи Сказку — переменные окружения
# Скопируй этот файл в .env.local и заполни значения
# ============================================================

# --- KIE.AI API ---
# Получить на: https://kie.ai/api-key
# Используется для генерации текста (Claude) и озвучки (ElevenLabs)
KIE_API_KEY=your_kie_api_key_here

# Модель для генерации сказок (можно заменить на claude-opus-4-6 для лучшего качества)
KIE_MODEL=claude-sonnet-4-6

# --- SUPABASE ---
# Получить на: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- ПРИЛОЖЕНИЕ ---
# URL сайта (без слеша в конце). На Vercel: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- АНАЛИТИКА (опционально) ---
# Yandex Metrika ID (только цифры, например: 12345678)
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# --- КОНТАКТЫ ---
# Email для формы обратной связи
CONTACT_EMAIL=hello@yourdomain.com
